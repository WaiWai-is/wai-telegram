# WAI Telegram AI - Production Environment Variables
# Copy this file to .env.production and fill in the values

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL=postgresql+asyncpg://telegram:YOUR_SECURE_PASSWORD@localhost:5432/telegram_ai
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD

# ===========================================
# REDIS
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# TELEGRAM API
# ===========================================
TELEGRAM_API_ID=28306719
TELEGRAM_API_HASH=your_telegram_api_hash

# Telegram Bot token (get from @BotFather) — used for sending digests to users
TELEGRAM_BOT_TOKEN=

# ===========================================
# ENCRYPTION
# ===========================================
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key

# ===========================================
# JWT / AUTH
# ===========================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_jwt_secret_key

# ===========================================
# OPENAI (Embeddings)
# ===========================================
OPENAI_API_KEY=sk-your-openai-api-key

# ===========================================
# ANTHROPIC (Digests)
# ===========================================
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ===========================================
# APPLICATION
# ===========================================
ENVIRONMENT=production
DEBUG=false

# Sync configuration
SYNC_BATCH_SIZE=100
SYNC_DELAY_SECONDS=1.0
FLOOD_WAIT_MULTIPLIER=1.2

# Digest model
DIGEST_MODEL=claude-sonnet-4-6

# ===========================================
# FRONTEND
# ===========================================
# Required for stable Next.js Server Action IDs across deploys.
# Generate with: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=your_base64_32byte_key
NEXT_PUBLIC_API_URL=https://telegram.waiwai.is
