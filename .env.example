# Database
DATABASE_URL=postgresql+asyncpg://telegram:telegram_dev@localhost:5432/telegram_ai

# Redis
REDIS_URL=redis://localhost:6379

# Telegram API credentials (get from https://my.telegram.org)
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# Encryption key for Telegram sessions (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your_fernet_key

# OpenAI API key for embeddings
OPENAI_API_KEY=sk-...

# Anthropic API key for digest generation
ANTHROPIC_API_KEY=sk-ant-...

# JWT secret key (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your_jwt_secret

# Frontend API (optional in local dev)
NEXT_PUBLIC_API_URL=http://localhost:8000
